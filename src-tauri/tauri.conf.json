{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pixiv-slides",
  "version": "0.1.0",
  "identifier": "net.pixiv.slides",
  "build": {
    "beforeDevCommand": "./tools/frontend/fe.sh dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "./tools/frontend/fe.sh build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pixiv-slides",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
